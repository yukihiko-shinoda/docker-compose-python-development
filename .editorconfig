# http://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_size = 4
indent_style = space
trim_trailing_whitespace = true

[*.bat]
end_of_line = crlf
indent_style = tab

# - Two spaces for indentation level of pyproject.toml · Issue #1078 · astral-sh/rye
#   https://github.com/astral-sh/rye/issues/1078#issuecomment-2246239029
# > I don't see a specific recommendation, but they do use two spaces in the docs
[*.toml]
indent_size = 2

# Web & Configuration files (Frontend & Data formats)
[*.{js,jsx,ts,tsx,html,css,json,yaml,yml}]
indent_size = 2

[LICENSE]
insert_final_newline = false

[Makefile]
indent_style = tab
